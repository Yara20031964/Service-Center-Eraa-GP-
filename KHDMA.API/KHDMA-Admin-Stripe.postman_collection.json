{
  "info": {
    "_postman_id": "bcf5e7b2-3b85-48b4-82a9-0d2e854e4c3b",
    "name": "KHDMA Admin & Stripe APIs",
    "description": "Collection of all Bookings, Payments, Reviews Admin APIs and Stripe Client endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Admin Bookings",
      "item": [
        {
          "name": "Get All Bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/bookings?page=1&pageSize=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "bookings"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "customerId",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Booking Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/bookings/{{bookingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "bookings",
                "{{bookingId}}"
              ]
            }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"Customer requested cancellation due to delay\"",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/bookings/{{bookingId}}/cancel",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "bookings",
                "{{bookingId}}",
                "cancel"
              ]
            }
          }
        },
        {
          "name": "Get Booking History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/bookings/{{bookingId}}/history",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "bookings",
                "{{bookingId}}",
                "history"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Admin Payments",
      "item": [
        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/payments?page=1&pageSize=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "payments"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Payment Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/payments/{{paymentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "payments",
                "{{paymentId}}"
              ]
            }
          }
        },
        {
          "name": "Issue Refund (Stripe)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"{{paymentId}}\",\n  \"reason\": \"Service not delivered\",\n  \"refundAmount\": 50.00\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/payments/refund",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "payments",
                "refund"
              ]
            }
          }
        },
        {
          "name": "Provider Earnings Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/payments/provider-earnings/{{providerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
