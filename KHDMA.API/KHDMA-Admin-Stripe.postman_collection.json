    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.collectionVariables.set(\"baseUrl\", \"https://localhost:7199\");",
          "pm.collectionVariables.set(\"bookingId\", \"00000000-0000-0000-0000-000000000000\");",
          "pm.collectionVariables.set(\"paymentId\", \"00000000-0000-0000-0000-000000000000\");",
          "pm.collectionVariables.set(\"reviewId\", \"00000000-0000-0000-0000-000000000000\");",
          "pm.collectionVariables.set(\"providerId\", \"test-provider-id\");"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7199",
      "type": "string"
    },
    {
      "key": "bookingId",
      "value": "00000000-0000-0000-0000-000000000000",
      "type": "string"
    },
    {
      "key": "paymentId",
      "value": "00000000-0000-0000-0000-000000000000",
      "type": "string"
    },
    {
      "key": "reviewId",
      "value": "00000000-0000-0000-0000-000000000000",
      "type": "string"
    },
    {
      "key": "providerId",
      "value": "test-provider-id",
      "type": "string"
    }
  ]
