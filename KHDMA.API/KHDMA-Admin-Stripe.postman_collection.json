                "reviews",
                "{{reviewId}}"
              ]
            }
          }
        },
        {
          "name": "Hide or Delete Review",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/reviews/{{reviewId}}/status?isDeleted=false&isHidden=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "reviews",
                "{{reviewId}}",
                "status"
              ],
              "query": [
                {
                  "key": "isDeleted",
                  "value": "false"
                },
                {
                  "key": "isHidden",
                  "value": "true"
                }
              ]
            }
          }
        }
